---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="内容后台" description="使用 Pages CMS 管理网站内容。">
  <section class="section">
    <p class="eyebrow">内容后台</p>
    <h1>使用 Pages CMS 编辑网站</h1>
    <p class="page-intro lead">
      使用 GitHub 账号登录后，可以编辑博客、作品、个人资料和图片。保存内容后，Cloudflare Pages 会自动重新部署网站。
    </p>
    <a class="button" href="https://app.pagescms.org/">打开 Pages CMS</a>
  </section>
</BaseLayout>
