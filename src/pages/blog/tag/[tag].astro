---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`标签：${tag}`} description={`浏览标签“${tag}”下的博客文章。`}>
  <section class="section">
    <a class="text-link" href="/blog/">返回全部博客</a>
    <p class="eyebrow tag-page-eyebrow">文章标签</p>
    <h1>{tag}</h1>
    <p class="page-intro lead">共 {posts.length} 篇文章</p>

    <div class="article-list">
      {
        posts.map((post) => (
          <article class="article-row">
            {
              post.data.coverImage && (
                <a href={`/blog/${post.id}/`} aria-label={`阅读《${post.data.title}》`}>
                  <img class="article-row-cover" src={post.data.coverImage} alt="" loading="lazy" />
                </a>
              )
            }
            <div class="article-row-body">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('zh-CN')}
              </time>
              <h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
              {post.data.description && <p>{post.data.description}</p>}
              <div class="tag-list">
                {post.data.tags.map((postTag) => (
                  <a
                    href={`/blog/tag/${encodeURIComponent(postTag)}/`}
                    aria-current={postTag === tag ? 'page' : undefined}
                  >
                    {postTag}
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
