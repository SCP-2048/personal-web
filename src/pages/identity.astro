<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>设置后台密码 | 个人网站</title>
    <style>
      body {
        display: grid;
        min-height: 100vh;
        place-items: center;
        margin: 0;
        background: #f8f5ef;
        color: #27221d;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      main {
        width: min(100% - 32px, 680px);
        border: 1px solid #e6ded2;
        border-radius: 28px;
        padding: 32px;
        background: #fffaf2;
        box-shadow: 0 24px 80px rgb(62 45 28 / 10%);
      }

      p {
        line-height: 1.8;
      }

      .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 24px;
      }

      form {
        display: none;
        gap: 14px;
        margin-top: 24px;
      }

      label {
        display: grid;
        gap: 6px;
        font-weight: 700;
      }

      input {
        min-height: 44px;
        border: 1px solid #e6ded2;
        border-radius: 12px;
        padding: 0 12px;
        background: white;
        color: #27221d;
        font: inherit;
      }

      button,
      a {
        display: inline-flex;
        min-height: 44px;
        align-items: center;
        justify-content: center;
        border: 1px solid #8b5e34;
        border-radius: 999px;
        padding: 0 18px;
        color: #5d3d21;
        font-weight: 700;
        text-decoration: none;
      }

      button {
        background: #8b5e34;
        color: white;
        cursor: pointer;
      }

      code {
        border-radius: 6px;
        padding: 2px 6px;
        background: #f1e7d9;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>设置后台密码</h1>
      <p id="status">正在读取 Netlify Identity 邀请信息。如果没有自动弹出窗口，请点击下面的按钮。</p>
      <p>
        这个页面只用于创建或重置后台密码。密码设置完成后，会自动跳转到 <code>/admin/</code>。
      </p>
      <form id="invite-form">
        <label>
          新密码
          <input id="password" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <label>
          再输入一次新密码
          <input id="password-confirm" type="password" autocomplete="new-password" minlength="8" required />
        </label>
        <button type="submit">设置密码并进入后台</button>
      </form>
      <div class="actions">
        <button id="open-identity" type="button">打开登录窗口</button>
        <button id="recover-password" type="button">重置密码</button>
        <a href="/admin/">返回后台</a>
      </div>
    </main>

    <script is:inline>
      const status = document.getElementById('status');
      const openIdentity = document.getElementById('open-identity');
      const recoverPassword = document.getElementById('recover-password');
      const inviteForm = document.getElementById('invite-form');
      const password = document.getElementById('password');
      const passwordConfirm = document.getElementById('password-confirm');
      const authParams = new URLSearchParams(window.location.hash.slice(1));
      const inviteToken = authParams.get('invite_token');
      const hasInviteToken = authParams.has('invite_token');
      const hasRecoveryToken = authParams.has('recovery_token');
      const hasConfirmationToken = authParams.has('confirmation_token');
      const hasIdentityToken = hasInviteToken || hasRecoveryToken || hasConfirmationToken;
      const identityScriptId = 'netlify-identity-widget';
      const identityScriptUrl = 'https://identity.netlify.com/v1/netlify-identity-widget.js';
      let identityPromise;
      let loginHandlerRegistered = false;

      const loadIdentity = () => {
        if (window.netlifyIdentity) {
          return Promise.resolve(window.netlifyIdentity);
        }

        if (identityPromise) {
          return identityPromise;
        }

        identityPromise = new Promise((resolve) => {
          const existingScript = document.getElementById(identityScriptId);

          const finish = () => {
            window.setTimeout(() => resolve(window.netlifyIdentity), 0);
          };

          if (existingScript) {
            existingScript.addEventListener('load', finish, { once: true });
            existingScript.addEventListener('error', () => resolve(undefined), { once: true });
            return;
          }

          const script = document.createElement('script');
          script.id = identityScriptId;
          script.src = identityScriptUrl;
          script.onload = finish;
          script.onerror = () => resolve(undefined);
          document.head.appendChild(script);
        });

        return identityPromise;
      };

      const registerLoginHandler = (netlifyIdentity) => {
        if (loginHandlerRegistered) {
          return;
        }

        netlifyIdentity.on('login', () => {
          document.location.href = '/admin/';
        });
        loginHandlerRegistered = true;
      };

      const openWidget = async () => {
        status.textContent = '正在加载 Netlify Identity...';
        const netlifyIdentity = await loadIdentity();

        if (!netlifyIdentity) {
          status.textContent = 'Netlify Identity 脚本没有加载成功。请关闭广告拦截器或浏览器隐私插件后刷新页面。';
          return;
        }

        registerLoginHandler(netlifyIdentity);

        if (hasInviteToken) {
          status.textContent = '检测到邀请链接。请直接在下面设置后台密码。';
          inviteForm.style.display = 'grid';
          return;
        }

        if (hasRecoveryToken || hasConfirmationToken) {
          status.textContent = '检测到密码重置或确认链接。请在弹出的窗口里完成设置。';
          netlifyIdentity.open();
          return;
        }

        status.textContent = '没有检测到邀请链接。你可以登录，或使用“重置密码”发送新的密码邮件。';
        netlifyIdentity.open('login');
      };

      const acceptInvite = async (event) => {
        event.preventDefault();

        if (!inviteToken) {
          status.textContent = '没有检测到邀请 token。请从 Netlify 重新发送邀请邮件。';
          return;
        }

        if (password.value !== passwordConfirm.value) {
          status.textContent = '两次输入的密码不一致。';
          return;
        }

        status.textContent = '正在设置密码...';

        try {
          const response = await fetch('/.netlify/identity/verify', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              token: inviteToken,
              password: password.value,
              type: 'signup',
            }),
          });

          if (!response.ok) {
            const message = await response.text();
            throw new Error(message || '设置密码失败。');
          }

          status.textContent = '密码设置成功。正在进入后台...';
          window.location.href = '/admin/';
        } catch (error) {
          status.textContent =
            '设置密码失败。这个邀请链接可能已经使用过或过期了，请在 Netlify Identity 里删除用户后重新邀请。';
        }
      };

      if (hasIdentityToken) {
        openWidget();
      }

      inviteForm.addEventListener('submit', acceptInvite);
      openIdentity.addEventListener('click', openWidget);
      recoverPassword.addEventListener('click', async () => {
        const netlifyIdentity = await loadIdentity();

        if (netlifyIdentity) {
          registerLoginHandler(netlifyIdentity);
          netlifyIdentity.open('login');
        } else {
          status.textContent = 'Netlify Identity 脚本没有加载成功。请关闭广告拦截器或浏览器隐私插件后刷新页面。';
        }
      });
    </script>
  </body>
</html>
