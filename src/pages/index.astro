---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../content/site/profile.json';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featuredPost = allPosts.find(({ data }) => data.featured);
const posts = featuredPost ? [featuredPost] : allPosts.slice(0, 1);

const works = (await getCollection('works'))
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 3);
---

<BaseLayout title={`${profile.name}的个人网站`}>
  <section class="home-intro">
    <h1>{profile.name}的个人网站</h1>
  </section>

  <section class="section-stack">
    <section class="content-section" id="blog">
      <div class="section-heading">
        <div>
          <p class="eyebrow">博客</p>
          <h2>想法、经历和技术文章</h2>
        </div>
        <a class="text-link" href="/blog/">查看全部博客</a>
      </div>

      <div class="article-list">
        {
          posts.map((post) => (
            <article class="article-row">
              {
                post.data.coverImage && (
                  <a href={`/blog/${post.id}/`} aria-label={`阅读《${post.data.title}》`}>
                    <img
                      class="article-row-cover"
                      src={post.data.coverImage}
                      alt=""
                      loading="lazy"
                    />
                  </a>
                )
              }
              <div class="article-row-body">
                <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('zh-CN')}</time>
                <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
                {post.data.description && <p>{post.data.description}</p>}
                <div class="tag-list">
                  {post.data.tags.map((tag) => (
                    <a href={`/blog/tag/${encodeURIComponent(tag)}/`}>{tag}</a>
                  ))}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-section" id="works">
      <div class="section-heading">
        <div>
          <p class="eyebrow">作品</p>
          <h2>程序和项目展示</h2>
        </div>
        <a class="text-link" href="/works/">查看全部作品</a>
      </div>

      <div class="post-grid">
        {
          works.map((work) => (
            <a
              class="post-card"
              href={work.data.repo ?? '/works/'}
              aria-label={work.data.repo ? `在 GitHub 查看${work.data.title}` : `查看${work.data.title}`}
            >
              <div>
                <p class="post-meta">{work.data.date.toLocaleDateString('zh-CN')}</p>
                <h3>{work.data.title}</h3>
                <p>{work.data.description}</p>
              </div>
              <span>{work.data.technologies.join(' / ')}</span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="content-section" id="contact">
      <div class="section-heading">
        <div>
          <p class="eyebrow">联系</p>
          <h2>邮箱、电话和 GitHub</h2>
        </div>
        <a class="text-link" href="/contact/">查看联系页</a>
      </div>

      <div class="contact-grid">
        <a class="contact-card" href={`mailto:${profile.email}`}>
          <span>邮箱</span>
          <strong>{profile.email}</strong>
        </a>
        <a class="contact-card" href={`tel:${profile.phone}`}>
          <span>电话</span>
          <strong>{profile.phone}</strong>
        </a>
        <a class="contact-card" href={profile.github}>
          <span>GitHub</span>
          <strong>{profile.github}</strong>
        </a>
      </div>
    </section>
  </section>
</BaseLayout>
